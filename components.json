CREATE TABLE "new_admin_settings" (
    "id" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    "username" TEXT NOT NULL DEFAULT 'Ali',
    "passwordHash" TEXT NOT NULL,
    "whatsappNumber" TEXT,
    "createdAt" DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    "updatedAt" DATETIME NOT NULL
);
INSERT INTO "new_admin_settings" ("createdAt", "id", "passwordHash", "updatedAt", "whatsappNumber") SELECT "createdAt", "id", "passwordHash", "updatedAt", "whatsappNumber" FROM "admin_settings";
DROP TABLE "admin_settings";
ALTER TABLE "new_admin_settings" RENAME TO "admin_settings";
